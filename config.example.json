{
  "app": {
    "name": "AI-Pessoal",
    "language": "pt-BR",
    "data_dir": "~/.ai-pessoal"
  },
  "ollama": {
    "base_url": "http://127.0.0.1:11434",
    "model_default": "qwen2.5:7b",
    "model_reasoning": null,
    "timeout_seconds": 120
  },
  "chat": {
    "max_history_messages": 20,
    "temperature": 0.7,
    "system_prompt": "Você é o AI-Pessoal, um assistente pessoal prestativo, claro e respeitoso. Responda em português do Brasil. Não invente fatos sobre o usuário; use apenas o contexto fornecido. Se não souber, diga."
  },
  "modes": {
    "note_prefix": ".",
    "question_prefix": "?"
  },
  "privacy": {
    "allow_network_tools": false,
    "allow_shell": false
  },
  "features": {
    "long_term_memory": true,
    "semantic_search": true,
    "cortana_bridge": false,
    "reminders": false
  },
  "cortana": {
    "enabled": false,
    "base_url": "http://127.0.0.1:8787",
    "poll_seconds": 3,
    "timeout_seconds": 600,
    "default_output_type": "summary"
  },
  "semantic": {
    "embed_model": "nomic-embed-text",
    "min_score": 0.35,
    "max_results": 12
  },
  "documents": {
    "chunk_chars": 900,
    "chunk_overlap": 120
  },
  "context": {
    "active_project": null
  }
}
